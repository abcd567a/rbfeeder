#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_build:
	# Generate protobuf files
	protoc-c --c_out=. rbfeeder.proto

	# Build rbfeeder
	make

override_dh_auto_clean:
	# Clean protobuf-generated files
	rm -f rbfeeder.pb-c.c rbfeeder.pb-c.h rbfeeder.pb-c.o
	make clean || true

override_dh_auto_install:
	install -D -m 755 rbfeeder debian/rbfeeder/usr/bin/rbfeeder
	install -D -m 755 dump1090-rb debian/rbfeeder/usr/bin/dump1090-rb
	install -D -m 644 etc/rbfeeder.ini debian/rbfeeder/etc/rbfeeder.ini
